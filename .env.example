# ── App ─────────────────────────────────────────────
# Both keys are auto-generated on first run if left blank.
SECRET_KEY=
ENCRYPTION_KEY=
DEBUG=true
# Loopback only. Set HOST=0.0.0.0 if you want to drive the app from a
# phone or other machine on your LAN — but that exposes your library
# and chat sessions to anyone on the same network, so do it knowingly.
HOST=127.0.0.1
PORT=16888

# ── AI Provider (BYOK — set ONE of these) ───────────
# Used by the chat planner, analyzer, and generator agents.
# You can also configure a per-user provider/key in Settings inside the app.
#
# OpenRouter is a unified gateway — one key unlocks Claude, GPT, Gemini,
# Llama, Mistral, etc. through a single account. Useful if you want to
# switch between premium models without juggling multiple keys. Get a key
# at https://openrouter.ai/keys.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Scout (BYOK, all optional — features degrade gracefully) ──
YOUTUBE_API_KEY=
TIKHUB_API_KEY=
PEXELS_API_KEY=

# ── YouTube Upload OAuth (optional — only if uploading to YouTube) ──
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:16888/api/settings/youtube-callback

# ── TikTok Upload OAuth (optional — only if uploading to TikTok) ──
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:16888/api/settings/tiktok-upload-callback

# ── Frontend ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
